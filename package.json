{
  "name": "piemonte-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c green,blue \"vite\" \"pnpm --filter server dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "pnpm --filter server start",
    "seeds": "tsx scripts/generate-seeds.ts",
    "regen-search-index": "tsx scripts/regen-search-index.ts",
    "resolve-images": "tsx scripts/resolve-image-urls.ts",
    "test:e2e:local": "playwright test --project local",
    "test:e2e:remote": "playwright test --project remote"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "clsx": "^2.1.1",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.7"
    }
  }
}
